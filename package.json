{
  "name": "aetheria-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "GOOGLE_GENAI_API_KEY=$GEMINI_API_KEY npm run dev --workspace=@aetheria/explorer",
    "build": "npm run build --workspace=@aetheria/explorer",
    "lint": "npm run lint --workspaces --if-present",
    "frontend:dev": "npm run dev --workspace=@aetheria/explorer",
    "frontend:build": "npm run build --workspace=@aetheria/explorer",
    "api:dev": "npm run dev --workspace=@aetheria/api",
    "api:build": "npm run build --workspace=@aetheria/api",
    "cap:sync": "npm run frontend:build && npx cap sync",
    "cap:ios": "npx cap add ios",
    "cap:android": "npx cap add android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@genkit-ai/firebase": "^1.30.1",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "capacitor-native-biometric": "^4.2.2",
    "motion": "^12.38.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@types/node": "^20",
    "concurrently": "^9.1.0",
    "dotenv": "^16.4.5",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "next": "^16.2.0"
  }
}
